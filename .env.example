# Google AdSense — optional override (defaults to ca-pub-4404421875307576 in code)
# VITE_ADSENSE_CLIENT=ca-pub-4404421875307576

# Optional display ad unit for chapter pages (create in AdSense → Ads → By ad unit)
VITE_ADSENSE_SLOT_ARTICLE=1234567890

# Google Analytics 4 — optional override (defaults to G-TWXVPC5C8V in code)
# VITE_GA4_MEASUREMENT_ID=G-TWXVPC5C8V

# Agent Overseer — show HRIS sync UI when enabled (secrets stay server-side)
# VITE_AO_HRIS_ENABLED=true
# Set on Cloudflare Worker (wrangler secret put HRIS_TOKEN / HRIS_ENDPOINT):
#   HRIS_ENDPOINT=https://your-hris.example.com/ingest
#   HRIS_TOKEN=your-secret-token
